# Circle App Kit Configuration (Required for App Kit examples)
KIT_KEY=your_circle_kit_key_here
PRIVATE_KEY=your_wallet_private_key_here

# Circle API Configuration (For Circle Web3 Services SDK)
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Web3 Configuration (Optional - defaults to public RPCs)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key
ALCHEMY_KEY=your_alchemy_api_key_here

# Optional: Custom RPC URLs for different chains
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-api-key
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-api-key
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-api-key

# Optional: Testnet URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-api-key

# Optional: Solana private key for cross-chain examples
SOLANA_PRIVATE_KEY=your_solana_private_key_in_base58_format

# Optional: Fee collection addresses
PLATFORM_FEE_ADDRESS=your_ethereum_fee_address
EVM_FEE_ADDRESS=your_evm_fee_collection_address
SOLANA_FEE_ADDRESS=your_solana_fee_collection_address
